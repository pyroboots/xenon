console.writeLine{"hello!"}
person = type {
    name = t_str,
    age = t_num,
    alive = t_bool,

    kill = func {{}, [[
        alive = false
    ]]},
    setAge = func {{newAge = t_num}, [[
        age = newAge
    ]]}
}

closed john = person {
    name = "john",
    age = 23,
    alive = true
}

john:setAge{newAge = 99}
john:kill{}
console.writeLine{"john age:", john.age}
