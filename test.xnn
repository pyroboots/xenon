person = type {[[person]],
    name = t_str,
    age = t_num,
    alive = t_bool
}

john = person {
    name = "John",
    age = 30,
    alive = true
}

foo = func {{p = t_person}, [[
    console.outLn{a.p.name}
]], t_void}

foo{
    p = john
}

console.outLn{#john}

arr = array {{t_str}, "hello", ", ", "world!"}
console.outLn{str.join{", ", arr}}

bar = dict {{t_str, t_str}, 
    ["foo"] = "xob",
    ["baz"] = "bar"
}

console.outLn{array.contains{arr, "hello"}}

Color = enum {[[Color]], [[Red]], [[Green]]}

Person = type {[[Person]],
    name = t_str,
    color = t_Color,
    greet = func {{}, [[
        console.outLn{this.name}
    ]], t_void},
}

john = Person {
    name = "John",
    color = Color.Red
}

john.greet{}